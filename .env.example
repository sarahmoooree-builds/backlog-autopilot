# Backlog Autopilot — example environment configuration
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# `.env.example` is committed so new contributors know which variables the
# pipeline reads. All variables are loaded by `config.py` via python-dotenv.

# ---------------------------------------------------------------------------
# GitHub
# ---------------------------------------------------------------------------

# Repo that Backlog Autopilot monitors and sends work to (owner/name).
TARGET_REPO=sarahmoooree-builds/finserv-platform

# Personal access token used by github_client.py to read issues and PRs.
# A classic token with `repo` scope (or a fine-grained token with
# Issues: read + Pull requests: read on TARGET_REPO) is sufficient. Leave
# empty for unauthenticated access (subject to a much lower rate limit).
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Devin API
# ---------------------------------------------------------------------------

# Devin v3 service-user API key. Create at https://app.devin.ai/ →
# org settings → API. Needs ManageOrgSessions + ViewOrgSessions.
DEVIN_API_KEY=

# Organization ID in the form `org-xxxxxxxx...`. Visible at
# https://app.devin.ai/ → org settings. Used to build the v3 base URL
# https://api.devin.ai/v3/organizations/{DEVIN_ORG_ID}.
DEVIN_ORG_ID=

# ---------------------------------------------------------------------------
# Timeouts (seconds)
# ---------------------------------------------------------------------------

# Max wall time for a single Devin session in each stage before we give up
# polling and record a timeout.
INGEST_TIMEOUT=480
PLANNER_TIMEOUT=480
SCOPE_TIMEOUT=600
OPTIMIZER_TIMEOUT=480

# Seconds between status polls while a Devin session is running.
POLL_INTERVAL=10

# ---------------------------------------------------------------------------
# Concurrency
# ---------------------------------------------------------------------------

# Upper bound on simultaneous Devin sessions Backlog Autopilot will launch.
DEVIN_MAX_CONCURRENT_SESSIONS=5

# ---------------------------------------------------------------------------
# Slack notifications (optional)
# ---------------------------------------------------------------------------

# Incoming webhook URL used by notifications.py. Leave empty to disable all
# Slack sends — the pipeline will continue to run normally. Create one at
# https://api.slack.com/apps → Incoming Webhooks.
SLACK_WEBHOOK_URL=

# Public URL of the Streamlit app, used in Slack messages to deep-link
# approvers to the approval queue (e.g. https://backlog-autopilot.example.com).
STREAMLIT_APP_URL=
